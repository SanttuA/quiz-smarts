{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "browser": true,
    "es2024": true,
    "node": true
  },
  "ignorePatterns": [
    "coverage/**",
    "dist/**",
    "node_modules/**",
    "playwright-report/**",
    "src/routeTree.gen.ts",
    "test-results/**"
  ]
}
